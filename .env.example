# =============================================================================
# SmartSummarizer AI — Environment Variables
# Copy this file to ".env" and fill in your key. NEVER commit your real .env.
# Only the server reads these values, so your key is never sent to the browser.
# =============================================================================

# Which provider to use: "gemini" or "openai"
AI_PROVIDER=gemini

# --- Google Gemini (default, has a generous free tier) ---
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- OpenAI (alternative) ---
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Port the Express backend listens on (the Vite dev server proxies /api here)
PORT=5000
